[Unit]
Description=TPU dashboard — in-memory HBM/duty time series + web UI on :8082
After=tpu-heartbeat-web.service network.target
Wants=tpu-heartbeat-web.service

[Service]
ExecStart=/usr/bin/python3 /home/shared/dashboard/tpu-dashboard.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
